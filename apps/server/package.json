{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run src/index.ts",
    "smoke:ai": "bun run src/scripts/ai-smoke.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@OpenDiagram/auth": "workspace:*",
    "@OpenDiagram/db": "workspace:*",
    "@OpenDiagram/env": "workspace:*",
    "@OpenDiagram/harness": "workspace:*",
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "elkjs": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@OpenDiagram/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
