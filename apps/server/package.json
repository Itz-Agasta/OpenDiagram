  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@OpenDiagram/auth": "workspace:*",
    "@OpenDiagram/db": "workspace:*",
    "@OpenDiagram/env": "workspace:*",
    "@OpenDiagram/harness": "workspace:*",
    "@ai-sdk/google": "^4.0.5",
    "@ai-sdk/groq": "^4.0.5",
    "@ai-sdk/openai": "^4.0.5",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "evlog": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@OpenDiagram/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
