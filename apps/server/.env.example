# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# Optional direct connection used by Drizzle migrations.
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

# Optional authentication
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
COOKIE_DOMAIN=

# Platform AI
GROQ_API_KEY=
# GROQ_API_KEYS=key1,key2,key3
GOOGLE_GENERATIVE_AI_API_KEY=
AI_PLATFORM_ENABLED=true

# BYOK credential encryption
# openssl rand -base64 32
BYOK_ENCRYPTION_KEY=
# BYOK_ENCRYPTION_KEYS=primary=base64-key,next=base64-key
# BYOK_ENCRYPTION_KEY_ID=primary

# Optional Cognee integration
COGNEE_BASE_URL=
COGNEE_API_KEY=

NODE_ENV=development
